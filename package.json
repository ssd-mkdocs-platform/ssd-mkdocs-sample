{
  "name": "spec-driven-docs-infra",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "description": "生成AI時代のドキュメント基盤",
  "scripts": {
    "mkdocs": "uv run mkdocs serve --livereload",
    "mkdocs:build": "uv run mkdocs build",
    "mkdocs:build:svg": "node scripts/mkdocs-svg.mjs",
    "mkdocs:build:pdf": "node scripts/mkdocs-pdf.mjs",
    "mkdocs:pdf": "pnpm mkdocs:build:pdf",
    "lint:text": "textlint README.md \"docs/**/*.md\"",
    "lint:text:fix": "textlint --fix README.md \"docs/**/*.md\"",
    "infra:build-image": "pwsh -File infra/scripts/Build-Image.ps1",
    "infra:deploy-handson-env": "pwsh -File infra/scripts/Deploy-HandsonEnv.ps1",
    "infra:remove-handson-env": "pwsh -File infra/scripts/Remove-HandsonEnv.ps1",
    "infra:test": "pwsh -File infra/scripts/tests/Run-AllTests.ps1"
  },
  "devDependencies": {
    "@marp-team/marp-cli": "^4.2.3",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "rulesync": "^5.2.2",
    "textlint": "^14.4.0",
    "textlint-rule-no-mix-dearu-desumasu": "^6.0.4",
    "textlint-rule-preset-icsmedia": "github:ics-creative/textlint-rule-preset-icsmedia",
    "textlint-rule-preset-ja-spacing": "^2.4.3",
    "textlint-rule-preset-japanese": "^10.0.3",
    "textlint-rule-preset-jtf-style": "^2.3.14",
    "textlint-rule-prh": "^6.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "puppeteer"
    ]
  }
}
